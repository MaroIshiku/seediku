# Seediku nutzt docker-compose.yml standardmäßig ohne .env-Variablen.
# Diese Datei ist nur ein Fallback für lokale Experimente oder eigene Overrides.

TZ=Europe/Berlin
ISHIKU_APP_URL=http://localhost:8509
ISHIKU_LOG_LEVEL=info

# Primär steht das Setup-Secret direkt in docker-compose.yml.
# Fallback für docker run oder eigene Overrides:
ISHIKU_SETUP_SECRET=replace-with-a-long-random-setup-secret

QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=adminadmin
